generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ProsperLink models
model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  walletAddress String?
  walletBalance Float          @default(0)
  role          String         @default("INVESTOR") // INVESTOR | OWNER | BOTH
  kycStatus     String         @default("PENDING")  // PENDING | VERIFIED | REJECTED
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts         Account[]
  sessions         Session[]
  tokenHoldings    TokenHolding[]
  payouts          Payout[]
  ownedProperties  Property[]     @relation("OwnedProperties")
  documents        Document[]
}

model Property {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  description   String
  type          String
  imageUrl      String
  address       String
  city          String
  state         String
  totalValue    Float
  totalTokens   Int
  tokenPrice    Float
  annualYield   Float
  fundedAmount  Float          @default(0)
  status        String         @default("FUNDING") // DRAFT|REVIEW|FUNDING|FUNDED|ACTIVE|CLOSED
  adminComment  String?
  spvEntity     String
  jurisdiction  String
  contractAddr  String?
  ownerId       String?
  highlights    String[]       @default([])
  bedrooms      Int?
  bathrooms     Int?
  sqft          Int?
  yearBuilt     Int?
  createdAt     DateTime       @default(now())
  owner         User?          @relation("OwnedProperties", fields: [ownerId], references: [id])
  tokenHoldings TokenHolding[]
  payouts       Payout[]
  documents     Document[]
}

model TokenHolding {
  id               String   @id @default(cuid())
  userId           String
  propertyId       String
  tokenCount       Int
  purchasePrice    Float
  ownershipPercent Float
  purchasedAt      DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
  property         Property @relation(fields: [propertyId], references: [id])
}

model Payout {
  id         String    @id @default(cuid())
  userId     String
  propertyId String
  amount     Float
  type       String    // RENTAL_INCOME | DISTRIBUTION | SALE_PROCEEDS
  status     String    @default("COMPLETED") // SCHEDULED|PROCESSING|COMPLETED|FAILED
  paidAt     DateTime?
  txHash     String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
  property   Property  @relation(fields: [propertyId], references: [id])
}

model Document {
  id         String    @id @default(cuid())
  propertyId String
  uploaderId String
  name       String
  category   String    // FINANCIAL | LEGAL | PROPERTY | COMPLIANCE
  url        String
  status     String    @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | REJECTED | DRAFT
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  property   Property  @relation(fields: [propertyId], references: [id])
  uploader   User      @relation(fields: [uploaderId], references: [id])
}
